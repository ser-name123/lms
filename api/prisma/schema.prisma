model LmsCourse {
  id            String   @id @default(uuid())
  code          String   @unique
  title         String
  category      String
  level         String
  studentsCount Int      @default(0)
  teachersCount Int      @default(0)
  status        String   @default("Active")
  createdAt     String
  description   String
}

model LmsAssignment {
  id               String   @id @default(uuid())
  title            String
  courseCode       String
  courseTitle      String
  category         String
  studentsCount    Int      @default(0)
  submissionsCount Int      @default(0)
  evaluatedCount   Int      @default(0)
  dueDate          String
  status           String   @default("Active")
  description      String
}

model LmsAssessment {
  id             String   @id @default(uuid())
  title          String
  courseCode     String
  courseTitle    String
  questionsCount Int
  duration       Int
  category       String
  avgScore       Float    @default(0)
  status         String   @default("Active")
