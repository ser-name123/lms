model Invoice {
  id        String          @id @default(uuid())
  number    String          @unique
  // Optional: an invoice can bill a registered student OR a custom/external
  // recipient (whose name + email live in the notes payload).
  studentId String?
  student   StudentProfile? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  amount    Decimal         @db.Decimal(10, 2)
  currency  String          @default("USD")
  status    InvoiceStatus   @default(DRAFT)
  issuedAt  DateTime        @default(now())
  dueAt     DateTime?
  paidAt    DateTime?
  notes     String?

  // ── Finance & Reporting: fee-plan billing + partial payment tracking ──
  feePlanId     String?   // FeePlan this invoice was generated from (plain id)
  assignmentId  String?   // StudentFeeAssignment that generated a recurring invoice
  periodLabel   String?   // "March 2026" for recurring invoices
  periodStart   DateTime?
  periodEnd     DateTime?
  subtotal      Decimal?  @db.Decimal(10, 2) // sum of items before discount + tax
  discountAmount Decimal  @default(0) @db.Decimal(10, 2)
  taxAmount     Decimal   @default(0) @db.Decimal(10, 2)
  paidAmount    Decimal   @default(0) @db.Decimal(10, 2) // running total (partial payments)
  discountId    String?   // applied Discount (plain id)
  scholarshipId String?   // applied Scholarship (plain id)

