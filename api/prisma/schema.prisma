// LMS data model.
// DATABASE_URL points at local Docker Postgres today and at Supabase later;
// DIRECT_URL exists because Prisma migrations cannot run through a pooler.

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  // NestJS compiles to CommonJS; without this the generated client emits ESM
  // and ts-node/Node disagree about how to load it.
  moduleFormat = "cjs"
  runtime      = "nodejs"
}

// Prisma 7 keeps connection URLs out of the schema — see prisma.config.ts.
datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SUPERVISOR
  ACADEMIC_COACH
  TEACHER
  STUDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
  TRIAL
  PAUSED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EnrollmentStatus {
  TRIAL
  PENDING
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum ClassStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

enum BatchStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

// Per-session student attendance (attendance is session-based, not date-based).
enum StudentAttendanceStatus {
  PRESENT
  LATE
  ABSENT
  EXCUSED
  LEAVE_APPROVED
  NO_SHOW
}

enum TeacherAttendanceStatus {
  PRESENT
  LATE
  ABSENT
  CLASS_CANCELLED
}

enum CorrectionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubmissionStatus {
  ASSIGNED
  DRAFT
  SUBMITTED
  LATE_SUBMITTED
  UNDER_REVIEW
  EVALUATED
  RETURNED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

// ─── Identity ─────────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  firstName    String
  lastName     String
  role         Role
  status       UserStatus @default(ACTIVE)
  country      String?
  timezone     String?
  avatarUrl    String?
  lastLoginAt  DateTime?
  phone        String?
  gender       String?
  joiningDate  DateTime?
  salary       Decimal?   @db.Decimal(10, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  studentProfile StudentProfile?
  teacherProfile TeacherProfile?
  refreshTokens  RefreshToken[]
  leaveRequests  LeaveRequest[]
  payouts        Payout[]
  notifications  Notification[]

  @@index([role, status])
}

// Only the hash is stored, so a database leak cannot replay a session.
model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model StudentProfile {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentCode     String    @unique
  phone           String?
  gender          String?
  dateOfBirth     DateTime?
  guardianName    String?
  profession      String?
  fees            Decimal?  @db.Decimal(10, 2)
  joiningDate     DateTime?
  lastPaymentDate DateTime?
  nextPaymentDate DateTime?

  // Profile enrichment (managed from the Student Management hub)
  nationality        String?
  address            String?
  timeZone           String?

  // Academic information
  currentGrade       String?
  currentSchool      String?
  board              String?
  learningLevel      String?
  preferredLanguage  String?
  learningGoal       String?

  // Parent / Guardian (no parent login — admin manages, parent notified by email)
  parentName         String?
  parentRelationship String?
  parentEmail        String?
  parentMobile       String?
  parentWhatsapp     String?

  // Assigned Academic Coach (a User with role ACADEMIC_COACH; plain id, resolved in service)
  coachId            String?

  // Documents: JSON array of { id, type, label, url, uploadedAt, archived }
  documents          Json?

  // Freeze / On-hold
  onHoldReason       String?
  onHoldAt           DateTime?

  enrollments Enrollment[]
  submissions Submission[]
  invoices    Invoice[]
  attendance  ClassAttendee[]
  chatMessages ChatMessage[]
  batches     BatchStudent[]
  activities  StudentActivity[]
  transfers   StudentTransfer[]
  assessmentAttempts AssessmentAttempt[]
}

// A requested change (teacher / batch / course) that needs approval before it
// applies. Approve → the change is executed and a TIMELINE + AUDIT row logged.
model StudentTransfer {
  id              String         @id @default(uuid())
  studentId       String
  student         StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  kind            String         // TEACHER / BATCH / COURSE
  reason          String
  payload         Json           // { enrollmentId, toTeacherId } | { batchId } | { courseId, teacherId, status }
  fromLabel       String?
  toLabel         String?
  status          String         @default("PENDING") // PENDING / APPROVED / REJECTED
  requestedById   String?
  requestedByName String?
  decidedById     String?
  decidedByName   String?
  decidedAt       DateTime?
  createdAt       DateTime       @default(now())

  @@index([studentId, status])
  @@index([status])
}

// Immutable log for a student — every meaningful action appends one row.
// One table powers the Timeline, Audit Log, Private Notes and Communication
// History tabs (distinguished by `kind`). Nothing is ever deleted.
model StudentActivity {
  id          String         @id @default(uuid())
  studentId   String
  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  kind        String         // TIMELINE / AUDIT / NOTE / COMMUNICATION / STATUS
  type        String         // CREATED / STATUS_CHANGED / TEACHER_CHANGED / BATCH_CHANGED / COURSE_CHANGED / NOTE / EMAIL / WHATSAPP / SMS / CALL / NOTIFICATION / ...
  title       String
  description String?
  channel     String?        // COMMUNICATION only: EMAIL / WHATSAPP / SMS / NOTIFICATION / CALL / INTERNAL
  visibility  String         @default("STAFF") // STAFF = admin + coach only
  meta        Json?
  actorId     String?
  actorName   String?
  createdAt   DateTime       @default(now())

  @@index([studentId, kind])
  @@index([studentId, createdAt])
}

model TeacherProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teacherCode    String   @unique
  bio            String?
  specialisation String?
  hourlyRate     Decimal? @db.Decimal(10, 2)
  courseId       String?
  course         Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)

  // ── Teacher Management: teaching assignment ──
  subjects      String[] @default([]) // e.g. English, Mathematics
  levels        String[] @default([]) // e.g. Grade 1..5
  teachingModes String[] @default([]) // One to One / Group Class

  // ── Weekly availability ({ Monday: [{from,to}], ... }); teacher submits,
  //    admin approves ──
  availability            Json?
  availabilityApproved    Boolean   @default(false)
  availabilitySubmittedAt DateTime?

  // ── Profile enrichment (mirrors TeacherRegistration, editable by admin) ──
  gender          String?
  dateOfBirth     DateTime?
  nationality     String?
  timeZone        String?
  address         String?
  whatsapp        String?
  qualification   String?
  experienceYears String?
  languages       String[] @default([])
  joiningDate     DateTime?

  // Documents copied from the registration (relative /uploads paths)
  documents Json?

  // ── System-generated rating (0..5, cached) ──
  rating      Float?
  ratingCount Int?

  // Archived teachers are hidden from active management but not deleted.
  archived Boolean @default(false)

  enrollments Enrollment[]
  classes     ClassSession[]
  chatMessages ChatMessage[]
  batches     Batch[]
  assignments Assignment[]
  assessments Assessment[]
}

// ─── Catalogue ────────────────────────────────────────────────────────────────

model Level {
  id      String   @id @default(uuid())
  name    String   @unique
  order   Int
  courses Course[]
}

model Course {
  id            String       @id @default(uuid())
  title         String
  slug          String       @unique
  description   String?
  levelId       String?
  level         Level?       @relation(fields: [levelId], references: [id], onDelete: SetNull)
  price         Decimal      @db.Decimal(10, 2)
  durationWeeks Int          @default(12)
  status        CourseStatus @default(DRAFT)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  enrollments Enrollment[]
  classes     ClassSession[]
  assignments Assignment[]
  assessments Assessment[]
  teachers    TeacherProfile[]
  batches     Batch[]

  @@index([status])
}

model Package {
  id              String   @id @default(uuid())
  name            String   @unique
  description     String?
  price           Decimal  @db.Decimal(10, 2)
  classesPerMonth Int
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  enrollments Enrollment[]
}

// ─── Learning ─────────────────────────────────────────────────────────────────

model Enrollment {
  id          String           @id @default(uuid())
  studentId   String
  student     StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacherId   String?
  teacher     TeacherProfile?  @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  packageId   String?
  package     Package?         @relation(fields: [packageId], references: [id], onDelete: SetNull)
  status      EnrollmentStatus @default(PENDING)
  progress    Int              @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // A student sits in a given course once.
  @@unique([studentId, courseId])
  @@index([status])
}

model ClassSession {
  id         String         @id @default(uuid())
  courseId   String
  course     Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacherId  String
  teacher    TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  batchId    String?
  batch      Batch?         @relation(fields: [batchId], references: [id], onDelete: SetNull)
  title      String
  startsAt   DateTime
  endsAt     DateTime
  status     ClassStatus    @default(SCHEDULED)
  meetingUrl String?
  createdAt  DateTime       @default(now())

  // ── Lifecycle timestamps (Scheduled → Reminder → Teacher/Student Joined →
  //    In Progress → Completed → Attendance Locked) ──
  reminder24hSentAt DateTime?
  reminder1hSentAt  DateTime?
  reminder15mSentAt DateTime?
  teacherJoinedAt   DateTime?
  actualStartAt     DateTime?
  actualEndAt       DateTime?
  meetingId         String?
  sessionId         String?

  // Teacher attendance for this session
  teacherStatus      TeacherAttendanceStatus?
  teacherLateMinutes Int?

  // Locking (no edits once locked, unless an approved correction)
  attendanceLocked Boolean   @default(false)
  lockedAt         DateTime?

  attendees   ClassAttendee[]
  corrections AttendanceCorrection[]

  @@index([startsAt])
  @@index([teacherId, startsAt])
  @@index([batchId, startsAt])
  @@index([status])
}

model ClassAttendee {
  id        String         @id @default(uuid())
  classId   String
  class     ClassSession   @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  // Kept for backward-compat; `status` is the source of truth going forward.
  attended  Boolean        @default(false)

  // Join / leave tracking
  joinedAt     DateTime?
  leftAt       DateTime?
  durationMins Int?
  device       String?
  browser      String?
  ipAddress    String?

  // Computed / verified attendance
  status      StudentAttendanceStatus?
  lateMinutes Int?
  remarks     String?

  @@unique([classId, studentId])
  @@index([studentId])
}

// ─── Batches (a scheduled cohort of a course, with one teacher + N students) ───
model Batch {
  id        String      @id @default(uuid())
  code      String      @unique // BATCH-0001
  name      String
  courseId  String
  course    Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacherId String?
  teacher   TeacherProfile? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  level     String?
  status    BatchStatus @default(ACTIVE)
  startDate DateTime?
  endDate   DateTime?

  // Default weekly schedule (used to bulk-generate class sessions)
  daysOfWeek String[] @default([]) // ["Monday","Wednesday"]
  startTime  String?              // "09:00"
  endTime    String?              // "10:00"
  timeZone   String?
  capacity   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students BatchStudent[]
  classes  ClassSession[]
  assignments Assignment[]
  assessments Assessment[]

  @@index([courseId])
  @@index([teacherId])
  @@index([status])
}

model BatchStudent {
  id        String         @id @default(uuid())
  batchId   String
  batch     Batch          @relation(fields: [batchId], references: [id], onDelete: Cascade)
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  addedAt   DateTime       @default(now())

  @@unique([batchId, studentId])
  @@index([studentId])
}

// A teacher-raised request to fix a locked/computed attendance value. Admin
// reviews; the row itself is the immutable audit line (who/what/when/outcome).
model AttendanceCorrection {
  id         String       @id @default(uuid())
  classId    String
  class      ClassSession @relation(fields: [classId], references: [id], onDelete: Cascade)
  targetType String       // STUDENT / TEACHER
  studentId  String?      // StudentProfile id when targetType = STUDENT
  attendeeId String?      // ClassAttendee id when targetType = STUDENT

  fromStatus String?
  toStatus   String
  reason     String

  requestedById   String  // requesting user (teacher) id
  requestedByName String?
  status          CorrectionStatus @default(PENDING)
  reviewedById    String?
  reviewedByName  String?
  reviewNotes     String?
  reviewedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([classId])
  @@index([status])
}

model Assignment {
  id          String   @id @default(uuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueAt       DateTime?
  createdAt   DateTime @default(now())

  // ── Advanced Assignment Management ──
  batchId       String?
  batch         Batch?          @relation(fields: [batchId], references: [id], onDelete: SetNull)
  teacherId     String?
  teacher       TeacherProfile? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  createdById   String?         // User id of the author (admin/teacher)
  subject       String?
  chapter       String?
  topic         String?
  difficulty    String?         // EASY / MEDIUM / HARD
  type          String?         // HOMEWORK / WORKSHEET / ESSAY / PROJECT / MCQ / CODING / ...
  instructions  String?
  maxMarks      Int             @default(100)
  passingMarks  Int             @default(40)
  lateAllowed   Boolean         @default(true)
  latePenaltyPct Int            @default(0)
  publishAt     DateTime?       // for SCHEDULED assignments
  status        String          @default("DRAFT") // DRAFT/SCHEDULED/PUBLISHED/CLOSED/ARCHIVED
  locked        Boolean         @default(false)
  targetType    String          @default("BATCH") // BATCH / SELECTED
  targetStudentIds String[]     @default([])
  allowedFileTypes String[]     @default([]) // e.g. ["pdf","docx"] — empty = any
  maxFileSizeMb Int?            // per-file ceiling shown to students
  attachments   Json?           // [{ url, name }]
  rubric        Json?           // [{ name, max }]
  updatedAt     DateTime        @updatedAt

  submissions Submission[]

  @@index([status])
  @@index([teacherId])
  @@index([batchId])
}

model Submission {
  id           String           @id @default(uuid())
  assignmentId String
  assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status       SubmissionStatus @default(ASSIGNED)
  content      String?
  fileUrl      String?
  attachments  Json?            // [{ url, name }]
  isLate       Boolean          @default(false)
  penaltyApplied Int?           // percentage points deducted
  grade        Int?
  rubricScores Json?            // { rubricName: score }
  feedback     String?
  feedbackFileUrl String?       // voice/video/attachment feedback
  similarityPct Int?            // plagiarism: % word-overlap with peers
  returnedReason String?
  draftSavedAt DateTime?
  submittedAt  DateTime?
  evaluatedAt  DateTime?

  @@unique([assignmentId, studentId])
  @@index([status])
}

// ─── Assessments (online tests: Question Bank → Assessment → Attempt → Result) ─

// Reusable Question Bank entry. Objective types (MCQ/TRUE_FALSE/FILL_BLANK/MATCH)
// are auto-graded; subjective types (SHORT/LONG/ESSAY/CODING/AUDIO/SPEAKING/
// FILE_UPLOAD) are teacher-graded against `rubric`.
model Question {
  id            String   @id @default(uuid())
  subject       String
  chapter       String?
  topic         String?
  category      String?
  difficulty    String   @default("MEDIUM") // EASY / MEDIUM / HARD
  type          String   // MCQ / TRUE_FALSE / FILL_BLANK / MATCH / SHORT_ANSWER / LONG_ANSWER / ESSAY / CODING / AUDIO / SPEAKING / FILE_UPLOAD
  text          String
  options       Json?    // MCQ: [{ id, text, correct }]; MATCH: [{ left, right }]
  correctAnswer String?  // TRUE_FALSE / FILL_BLANK canonical answer
  marks         Int      @default(1)
  negativeMarks Float    @default(0)
  estimatedTime Int      @default(60) // seconds
  explanation   String?
  media         Json?    // [{ url, name, kind }]
  rubric        Json?    // subjective grading: [{ name, max }]
  language      String?  // CODING: default language (javascript/python/...)
  testCases     Json?    // CODING: [{ input, expected, sample }]
  createdById   String?
  version       Int      @default(1)
  archived      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assessmentQuestions AssessmentQuestion[]
  answers             AssessmentAnswer[]

  @@index([subject])
  @@index([type])
  @@index([difficulty])
  @@index([archived])
}

model Assessment {
  id            String          @id @default(uuid())
  title         String
  courseId      String?
  course        Course?         @relation(fields: [courseId], references: [id], onDelete: SetNull)
  batchId       String?
  batch         Batch?          @relation(fields: [batchId], references: [id], onDelete: SetNull)
  teacherId     String?
  teacher       TeacherProfile? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  createdById   String?
  subject       String?
  chapter       String?
  topic         String?
  category      String?
  type          String          @default("QUIZ") // QUIZ/WEEKLY_TEST/MONTHLY_TEST/UNIT_TEST/MID_TERM/FINAL_EXAM/ORAL_TEST/PRACTICE_TEST/MOCK_TEST
  instructions  String?

  // Rules
  durationMin           Int     @default(60)
  totalMarks            Int     @default(100)
  passingMarks          Int     @default(40)
  attemptsAllowed       Int     @default(1) // 0 = unlimited
  questionOrder         String  @default("FIXED") // FIXED / RANDOM
  allowBack             Boolean @default(true)
  showResultImmediately Boolean @default(false)
  negativeMarking       Boolean @default(false)

  // Question selection
  selectionMode String   @default("MANUAL") // MANUAL / RANDOM
  randomRules   Json?    // { subject, easy, medium, hard }

  // Scheduling window
  startAt   DateTime?
  endAt     DateTime?
  publishAt DateTime?
  status    String   @default("DRAFT") // DRAFT/SCHEDULED/PUBLISHED/LIVE/CLOSED/ARCHIVED
  locked    Boolean  @default(false)

  // Targeting
  targetType       String   @default("BATCH") // BATCH / SELECTED
  targetStudentIds String[] @default([])

  // Certificate
  certificateEnabled   Boolean @default(false)
  certificateThreshold Int     @default(70)

  // Proctoring (client-side tab-switch / copy detection)
  proctored Boolean @default(false)

  attachments Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions AssessmentQuestion[]
  attempts  AssessmentAttempt[]

  @@index([status])
  @@index([teacherId])
  @@index([batchId])
  @@index([courseId])
}

// Ordered link between an Assessment and a bank Question (with optional per-
// assessment marks override).
model AssessmentQuestion {
  id           String     @id @default(uuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  questionId   String
  question     Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  order        Int        @default(0)
  marks        Int?       // overrides Question.marks for this assessment

  @@unique([assessmentId, questionId])
  @@index([assessmentId])
}

// A single student sitting of an assessment. Objective marks land in autoScore
// on submit; subjective marks accumulate in manualScore during teacher review.
model AssessmentAttempt {
  id           String         @id @default(uuid())
  assessmentId String
  assessment   Assessment     @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  attemptNo    Int            @default(1)
  status       String         @default("IN_PROGRESS") // IN_PROGRESS/SUBMITTED/UNDER_EVALUATION/EVALUATED/PUBLISHED

  startedAt     DateTime  @default(now())
  submittedAt   DateTime?
  evaluatedAt   DateTime?
  publishedAt   DateTime?
  autoSubmitted Boolean   @default(false)
  timeSpentSec  Int?

  autoScore    Float   @default(0) // objective portion
  manualScore  Float   @default(0) // subjective portion
  score        Float   @default(0) // total after negative marking
  totalMarks   Int     @default(0)
  percentage   Float   @default(0)
  passed       Boolean @default(false)
  rank         Int?
  correctCount Int     @default(0)
  wrongCount   Int     @default(0)
  skippedCount Int     @default(0)

  teacherFeedback String?
  certificateUrl  String?
  certificateNo   String? // issued certificate number (set when eligible + published)

  // Proctoring
  violations Int   @default(0)
  proctorLog Json? // [{ type, at }]

  answers AssessmentAnswer[]

  @@unique([assessmentId, studentId, attemptNo])
  @@index([assessmentId])
  @@index([studentId])
  @@index([status])
}

model AssessmentAnswer {
  id              String            @id @default(uuid())
  attemptId       String
  attempt         AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId      String
  question        Question          @relation(fields: [questionId], references: [id], onDelete: Cascade)
  response        Json?             // selected option ids / text / fileUrl
  markedForReview Boolean           @default(false)
  isCorrect       Boolean?          // null until graded (subjective)
  awardedMarks    Float?
  maxMarks        Int               @default(1)
  rubricScores    Json?             // { rubricName: score }
  feedback        String?
  autoGraded      Boolean           @default(false)
  timeSpentSec    Int?

  @@unique([attemptId, questionId])
  @@index([attemptId])
}

// ─── Billing ──────────────────────────────────────────────────────────────────

model Invoice {
  id        String          @id @default(uuid())
  number    String          @unique
  // Optional: an invoice can bill a registered student OR a custom/external
  // recipient (whose name + email live in the notes payload).
  studentId String?
  student   StudentProfile? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  amount    Decimal         @db.Decimal(10, 2)
  currency  String          @default("USD")
  status    InvoiceStatus   @default(DRAFT)
  issuedAt  DateTime        @default(now())
  dueAt     DateTime?
  paidAt    DateTime?
  notes     String?

  payments Payment[]

  @@index([status])
}

model Payment {
  id          String        @id @default(uuid())
  invoiceId   String
  invoice     Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount      Decimal       @db.Decimal(10, 2)
  provider    String        @default("stripe")
  providerRef String?
  status      PaymentStatus @default(PENDING)
  paidAt      DateTime?
  createdAt   DateTime      @default(now())

  @@index([invoiceId])
}

model SystemSetting {
  key   String @id
  value String
}

enum CandidateStatus {
  NEW
  SHORTLISTED
  REJECTED
  WAITING
  APPROVED
}

model Candidate {
  id             String          @id @default(uuid())
  firstName      String
  lastName       String
  email          String          @unique
  phone          String?
  position       String          // e.g. "Quran Teacher", "Arabic Teacher"
  resumeUrl      String?
  status         CandidateStatus @default(NEW)
  notes          String?
  appliedAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([status])
}

enum LeaveType {
  SICK
  CASUAL
  ANNUAL
  UNPAID
  OTHER
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  DECLINED
}

model LeaveRequest {
  id           String             @id @default(uuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType    LeaveType          @default(CASUAL)
  startDate    DateTime
  endDate      DateTime
  reason       String
  status       LeaveRequestStatus @default(PENDING)
  adminNotes   String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([userId])
  @@index([status])
}

// ─── Trial Classes ────────────────────────────────────────────────────────────

enum TrialStatus {
  PENDING
  SCHEDULED
  COMPLETED
}

model TrialClass {
  id                 String      @id @default(uuid())
  name               String
  email              String
  mobile             String
  country            String
  course             String
  prefTeacherGender  String      // "Male", "Female", "Any"
  status             TrialStatus @default(PENDING)
  age                Int
  goals              String?
  scheduledTime      String?     // Date or text string
  assignedTeacher    String?
  meetLink           String?
