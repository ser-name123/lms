// ─── Public student self-registration ────────────────────────────────────────

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_INFO
}

// A prospective student's self-submitted application. Sits in PENDING until an
// admin reviews it; on approval a real User + StudentProfile is created and the
// generated identifiers below are filled in.
model StudentRegistration {
  id             String             @id @default(uuid())
  registrantType String             @default("STUDENT") // "STUDENT" or "PARENT"

  // Basic details
  firstName      String
  middleName     String?
  lastName       String
  gender         String?
  dateOfBirth    DateTime?
  nationality    String?
  country        String?
  state          String?
  city           String?
  address        String?

  // Contact details
  studentEmail   String
  studentMobile  String?
  parentEmail    String?
  parentMobile   String?
  emergencyContact String?
  whatsappNumber String?

  // Education details
  currentSchool  String?
  board          String?
  className      String?
  grade          String?
  subjects       String?
  language       String?

  // Course selection + learning mode
  courseCode     String?  // references LmsCourse.code
  courseTitle    String?
  batch          String?  // Morning / Evening / Weekend
  preferredTiming String?
  learningMode   String?  // ONLINE / OFFLINE / HYBRID

  // Guardian details
  fatherName      String?
  motherName      String?
  occupation      String?
  guardianRelation String?
  guardianAddress String?
  guardianEmail   String?
  guardianPhone   String?

  // Account credentials chosen by the applicant
  username       String?
  passwordHash   String

  // Review workflow
  status         RegistrationStatus @default(PENDING)
  reviewNotes    String?
  reviewedAt     DateTime?
  reviewedById   String?

  // Filled in on approval
  studentProfileId String?
  admissionNumber  String?
  rollNumber       String?
  approvedStudentCode String?

  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([status])
}

// ─── Public teacher self-registration ────────────────────────────────────────

// The teacher hiring pipeline. An application walks through these stages; the
// admin advances it stage-by-stage. ACTIVATED is the terminal success state and
// triggers creation of a real User + TeacherProfile with a generated code.
enum TeacherRegistrationStatus {
  APPLIED
  SCREENING
  INTERVIEW
  DEMO_CLASS
  APPROVAL
  TRAINING
  ACTIVATED
  REJECTED
  NEEDS_INFO
}

model TeacherRegistration {
  id             String                    @id @default(uuid())

  // Personal information
  firstName      String
  middleName     String?
  lastName       String
  gender         String?
  dateOfBirth    DateTime?
  nationality    String?
  country        String?
  state          String?
  city           String?
  address        String?

  // Contact
  email          String
  mobile         String?
  whatsappNumber String?

  // Professional details
  highestQualification String?
  university           String?
  passingYear          String?
  experienceYears      String?
  currentEmployer      String?
  expectedSalary       String?
  subjects             String?  // comma-separated subjects taught
  languages            String?  // comma-separated languages
  teachingMode         String?  // ONLINE / OFFLINE / HYBRID

  // Availability (Mon..Sun days + Morning/Afternoon/Evening slots)
  availabilityDays  String[] @default([])
  availabilitySlots String[] @default([])

  // Technical skills (Zoom, Google Meet, Teams, Whiteboard, LMS, ...)
  technicalSkills   String[] @default([])

  // Bank / payout details
  accountNumber  String?
  ifsc           String?
  bankName       String?
  upi            String?
  taxNumber      String?

  // Documents (relative /uploads paths, filled via the upload endpoint)
  resumeUrl             String?
  degreeUrl             String?
  certificatesUrl       String?
  govIdUrl              String?
  photoUrl              String?
  experienceLetterUrl   String?
  policeVerificationUrl String?

  // Account credentials chosen by the applicant
  username       String?
  passwordHash   String

  // Hiring pipeline
  status         TeacherRegistrationStatus @default(APPLIED)
  reviewNotes    String?
  interviewDate  DateTime?
  interviewNotes String?
  demoDate       DateTime?
  demoNotes      String?
  reviewedAt     DateTime?
  reviewedById   String?

  // Filled in on activation. The relation is SetNull on purpose: when the
  // teacher account is deleted the link must drop itself, otherwise this row
  // keeps claiming an ACTIVATED teacher that no longer exists. An ACTIVATED
  // row with a null link is therefore an archived hire, not a live one.
  teacherProfileId    String?
  teacherProfile      TeacherProfile? @relation(fields: [teacherProfileId], references: [id], onDelete: SetNull)
  approvedTeacherCode String?

  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@index([status])
}

// ─── Lead management (website inquiry → evaluation → trial → conversion) ──────

enum LeadStatus {
  NEW
  CONTACT_PENDING
  CONTACTED
  EVALUATION_SCHEDULED
  EVALUATION_COMPLETED
  TEACHER_ASSIGNED
  TRIAL_SCHEDULED
  TRIAL_COMPLETED
  WAITING_PARENT_DECISION
  CONVERTED
  REJECTED
  CLOSED
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// Lifecycle of a single trial (demo) class booked for a lead.
enum LeadTrialStatus {
  SCHEDULED
  RESCHEDULED
  COMPLETED
  NO_SHOW
  CANCELLED
}

// A prospective-student inquiry captured from the public website lead form.
// Walks the sales/academic pipeline via LeadStatus until CONVERTED (a real
// StudentProfile is created, mirroring the registration approval flow) or
// REJECTED/CLOSED.
model Lead {
  id           String       @id @default(uuid())
  leadNumber   String       @unique // e.g. LD-2026-000001

  // Section 1 — Student details
  studentFirstName String
  studentLastName  String
  gender           String?
  dateOfBirth      DateTime?
  currentGrade     String?
  currentSchool    String?
  country          String?
  timeZone         String?

  // Section 2 — Parent details
  parentName     String?
  relationship   String?
  email          String
  mobile         String
  whatsappNumber String?

  // Section 3 — Learning requirements
  // `interestedSubject` doubles as "What would you like to learn?"
  // (Quran / Arabic Language / Islamic Studies).
  interestedSubject     String?
  currentLevel          String?  // Beginner / Intermediate / Advanced
  preferredLanguage     String?
  preferredTeacherGender String? // Male / Female / Either
  // Superseded by preferredDate + preferredSlot. Kept because leads booked
  // under the old form still carry them and the detail page still reads them.
  preferredDays         String[] @default([])
  preferredTimeSlots    String[] @default([])

  // The visitor picks one concrete date and one 30-minute slot, chosen from
  // merged teacher availability rather than typing a free-text preference.
  preferredDate DateTime?
  preferredSlot String?   // "HH:mm" in preferredSlotTz
  preferredSlotTz String? // IANA zone the slot was displayed in

  sessionFor String? // MYSELF / FAMILY_MEMBER
  howFound   String? // FRIEND / SOCIAL_MEDIA / EMAIL / GOOGLE / OTHER

  // Dial code kept apart from `mobile` so the number stays comparable across
  // countries — "+91 98765" and "98765" are the same person.
  countryCode String?

  // Extra children on the same booking: [{ firstName, lastName }].
  // They share this lead's slot; conversion creates one Student account each.
  siblings Json?

  // Section 4 — Additional questions
  learningGoal        String?
  previousCoaching    String?
  specialRequirements String?
  medicalDisability   String?

  // Section 5 — Security / consent
  acceptPrivacy  Boolean @default(false)
  acceptTerms    Boolean @default(false)
  recaptchaToken String? // captured but not verified yet (stub)

  // Step 3 — Marketing / tracking (very useful for the marketing team)
  leadSource  String  @default("Website")
  ipAddress   String?
  browser     String?
  device      String?
  referralUrl String?
  utmSource   String?
  utmCampaign String?
  utmMedium   String?

  // Pipeline
  status   LeadStatus   @default(NEW)
  priority LeadPriority @default(MEDIUM)

  // Assignment (plain ids, resolved to names in queries — mirrors TrialClass)
  assignedCoachId String?
  assignedCoachAt DateTime?

  // Step 6 — Evaluation (scores stored as { key: 1..10 } JSON + overall %)
  evaluationScores Json?
  overallScore     Float?
  evaluationNotes  String?
  evaluatedAt      DateTime?
  evaluatedById    String?

  // Step 7 — Recommendation engine output
  recommendedLevel    String?
  recommendedBatch    String?
  recommendedTeacherId String?

  // Step 8 — Teacher assignment
  assignedTeacherId String?
  assignedTeacherAt DateTime?

  // Step 13 — Coach decision after the trial
  coachDecision      String?   // ENROLL / REJECT / FOLLOW_UP
  coachDecisionNotes String?
  coachDecisionAt    DateTime?

  // Conversion (Phase 4) — a real StudentProfile is created on ENROLL.
  // The singular pair points at the primary student; with siblings on the
  // booking, every created account is listed in `convertedStudents`
  // ([{ id, code, name }]) so none of them is lost.
  convertedStudentId   String?
  convertedStudentCode String?
  convertedStudents    Json?
  convertedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities LeadActivity[]
  trials     LeadTrial[]

  @@index([status])
  @@index([assignedCoachId])
  @@index([email])
}

// Step 9–12 — a scheduled trial/demo class for a lead, its meeting link,
// reminder state, attendance, and the teacher + parent feedback captured after.
model LeadTrial {
  id     String @id @default(uuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  // Assignment (TeacherProfile id, resolved to a name in queries)
  teacherId String?

  // Schedule (Step 9)
  scheduledAt     DateTime
  durationMins    Int      @default(30)
  timeZone        String?
  meetingProvider String?  // Zoom / Google Meet
  meetingLink     String?
  // Zoom's own ids, kept so the meeting can be updated or deleted when the
  // trial is rescheduled or cancelled instead of leaking orphaned meetings.
  meetingId       String?
  meetingHostUrl  String?
  status          LeadTrialStatus @default(SCHEDULED)

  // Reminders (Step 10) — the sweep stamps these when a reminder is dispatched
  reminder24hSentAt DateTime?
  reminder1hSentAt  DateTime?

  // Attendance (Step 11)
  attendance String?   // PRESENT / ABSENT
  attendedAt DateTime?

  // Feedback (Step 12)
  teacherRating           Int?     // 1–5
  teacherFeedback         String?
  teacherRecommendsEnroll Boolean?
  parentRating            Int?
  parentFeedback          String?
  parentInterested        Boolean?

  // ── Step 14 — the teacher's trial report ──────────────────────────────────
  // Filled in by the teacher the trial is assigned to, during or after the
  // session. Everything lives on the trial rather than the lead because a
  // student can sit more than one trial: two teachers may hear two different
  // answers, and writing straight onto the lead would lose who was told what.

  // What the teacher actually covered. Separate flags, not one "done" tick,
  // so a half-finished trial can say which half.
  coveredIntro        Boolean @default(false) // introduced the academy
  coveredPresentation Boolean @default(false) // company presentation / video
  coveredDemoLesson   Boolean @default(false) // sample Quran / Arabic lesson
  coveredPackages     Boolean @default(false) // explained subscription packages
  verifiedDetails     Boolean @default(false) // checked the submitted information

  // Details collected from the family during the trial.
  studentAge         Int?
  studentDob         DateTime?
  guardianName       String?
  guardianRelation   String?
  guardianPhone      String?
  guardianEmail      String?
  preferredPackage   String?
  preferredDays      String[] @default([])
  preferredTime      String?
  preferredStartDate DateTime?

  // The teacher's assessment and recommendation.
  assessedLevel       String? // Beginner / Elementary / Intermediate / Advanced
  recommendedCourseId String?
  recommendedCourse   String? // title snapshot, so a renamed course reads right
  reportNotes         String?
  // Null while the report is still a draft; stamped once the teacher submits.
  reportSubmittedAt   DateTime?

  // ── Missing-information form ──────────────────────────────────────────────
  // Families often will not settle on a package or a start date during the
  // trial itself. The coach sends them a link afterwards and their answers
  // land straight back on this row.
  //
  // Only the SHA-256 of the token is kept: a leaked database should not hand
  // out working links. The plaintext is shown to the coach once, at issue.
  infoTokenHash      String?
  infoTokenExpiresAt DateTime?
  infoRequestedAt    DateTime?
  infoRequestedById  String?
  infoSubmittedAt    DateTime?

  notes       String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([leadId])
  @@index([teacherId])
  @@index([scheduledAt])
}

// Immutable audit line for a lead — every meaningful action appends one row,
// powering the "Activity Timeline" tab.
model LeadActivity {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String   // CREATED / STATUS_CHANGED / ASSIGNED / EVALUATED / NOTE / ...
  message   String
  actorId   String?
  actorName String?
  createdAt DateTime @default(now())

  @@index([leadId])
}

// ─── Notification Management ──────────────────────────────────────────────────
// `type` stays a free-form String: 34 literals are already emitted from 16
// services, and NOTIFICATION_TYPES (notifications/registry.ts) maps each one to
// a category, priority and default channel set. An unregistered type still
// delivers — it just falls back to SYSTEM/MEDIUM/in-app.

enum NotificationCategory {
  ACADEMIC
  ATTENDANCE
  ASSIGNMENT
  ASSESSMENT
  FINANCE
  PROGRESS
  SYSTEM
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// The row's own lifecycle. Per-channel outcomes live on NotificationDelivery.
enum NotificationStatus {
  DRAFT
  SCHEDULED
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
  ARCHIVED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
  WHATSAPP
  SMS
}

enum BroadcastAudience {
  ALL
  ROLE
  COURSE
  BATCH
  STUDENTS
}

// One notification delivered to one user. The topbar bell reads these.
model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // LEAD_NEW / LEAD_ASSIGNED / ...
  title     String
  body      String?
  link      String?
  // `read` predates the module and is what the bell/widget still read; readAt
  // is the timestamp the reports need. The engine keeps both in step.
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  category    NotificationCategory @default(SYSTEM)
  priority    NotificationPriority @default(MEDIUM)
  status      NotificationStatus   @default(SENT)
  readAt      DateTime?
  archivedAt  DateTime?
  scheduledAt DateTime?
  // Who caused it — null for engine/system events.
  actorId     String?
  actorName   String?
  broadcastId String?
  broadcast   NotificationBroadcast? @relation(fields: [broadcastId], references: [id], onDelete: SetNull)
  templateCode String?
  meta        Json?

  deliveries NotificationDelivery[]

  @@index([userId, read])
  @@index([userId, archivedAt, createdAt])
  @@index([category])
  @@index([status])
  @@index([createdAt])
  @@index([broadcastId])
}

// One attempt to put a notification down one channel. This is the delivery log
// the admin panel reports on, and what the retry sweep walks.
model NotificationDelivery {
  id             String              @id @default(uuid())
  notificationId String
  notification   Notification        @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  channel        NotificationChannel
  status         NotificationStatus  @default(QUEUED)
  attempts       Int                 @default(0)
  lastError      String?
  // Set when the channel was deliberately not used (preference off, provider
  // not configured). Distinct from a failure so reports do not conflate them.
  skippedReason  String?
  target         String? // email address / push endpoint / phone
  providerRef    String?
  queuedAt       DateTime            @default(now())
  sentAt         DateTime?
  deliveredAt    DateTime?
  failedAt       DateTime?

  @@unique([notificationId, channel])
  @@index([status, channel])
  @@index([queuedAt])
}

// Per-user channel opt-in. Absent row = every channel on (the engine treats a
// missing row as the defaults below, so no backfill is needed).
model NotificationPreference {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  inApp          Boolean  @default(true)
  email          Boolean  @default(true)
  push           Boolean  @default(true)
  whatsapp       Boolean  @default(false)
  sms            Boolean  @default(false)
  // "Mute marketing" in the spec — announcements and other non-essential blasts.
  muteMarketing  Boolean  @default(false)
  // Categories this user has switched off entirely. CRITICAL always overrides.
  mutedCategories NotificationCategory[] @default([])
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

// Admin-editable message template. `isSystem` marks the seeded ones — those may
// be edited but not deleted, because the engine looks them up by code.
model NotificationTemplate {
  id          String               @id @default(uuid())
  code        String               @unique
  name        String
  description String?
  category    NotificationCategory @default(SYSTEM)
  priority    NotificationPriority @default(MEDIUM)
  channels    NotificationChannel[] @default([])
  subject     String
  bodyText    String
  bodyHtml    String?
  link        String?
  active      Boolean              @default(true)
  isSystem    Boolean              @default(false)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([category])
}

// An admin-composed send: broadcast now, or scheduled for later.
model NotificationBroadcast {
  id             String                @id @default(uuid())
  title          String
  body           String
  link           String?
  templateCode   String?
  category       NotificationCategory  @default(SYSTEM)
  priority       NotificationPriority  @default(MEDIUM)
  channels       NotificationChannel[] @default([])
  audience       BroadcastAudience     @default(ALL)
  roles          Role[]                @default([])
  courseId       String?
  batchId        String?
  studentIds     String[]              @default([])
  scheduledAt    DateTime?
  status         NotificationStatus    @default(DRAFT)
  recipientCount Int                   @default(0)
  sentCount      Int                   @default(0)
  failedCount    Int                   @default(0)
  sentAt         DateTime?
  cancelledAt    DateTime?
  createdById    String?
  createdByName  String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  notifications Notification[]

  @@index([status, scheduledAt])
}

// A browser Web Push endpoint. One user may have several (one per device).
model PushSubscription {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint   String   @unique
  p256dh     String
  auth       String
  userAgent  String?
  createdAt  DateTime @default(now())
  lastUsedAt DateTime?

  @@index([userId])
}

// ─── Student Progress Tracking ────────────────────────────────────────────────
// Foreign keys are plain ids (resolved in the service), mirroring
// StudentProfile.coachId — so the existing academic models stay untouched. The
// raw-SQL migration adds DB-level FKs for cascade integrity where it matters.

// A named skill within a course (English → Grammar, Vocabulary, ...). Graded
// assignments/assessments link to a skill; the engine rolls them into a %.
model ProgressSkill {
  id        String   @id @default(uuid())
  courseId  String
  name      String
  order     Int      @default(0)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([courseId, name])
  @@index([courseId])
}

// Cached per-student per-skill mastery %, recomputed by the progress engine.
model StudentSkillProgress {
  id         String   @id @default(uuid())
  studentId  String
  skillId    String
  percentage Float    @default(0)
  sampleSize Int      @default(0) // graded items that fed this figure
  updatedAt  DateTime @updatedAt

  @@unique([studentId, skillId])
  @@index([studentId])
}

// Structured teacher feedback — per-class quick ★ ratings + weekly/monthly notes.
model TeacherFeedback {
  id             String   @id @default(uuid())
  studentId      String
  teacherId      String?
  classSessionId String?
  kind           String   @default("CLASS") // CLASS / WEEKLY / MONTHLY
  participation  Int? // 1..5
  homework       Int?
  communication  Int?
  understanding  Int?
  behavior       Int?
  remarks        String?
  suggestions    String? // improvement tips
  actorId        String?
  actorName      String?
  createdAt      DateTime @default(now())

  @@index([studentId, kind])
  @@index([studentId, createdAt])
  @@index([teacherId])
}

// A learning goal set by the Academic Coach for a student.
model LearningGoal {
  id            String    @id @default(uuid())
  studentId     String
  title         String
  description   String?
  skillId       String?
  currentPct    Int       @default(0)
  targetPct     Int       @default(100)
  deadline      DateTime?
  status        String    @default("ACTIVE") // ACTIVE / ACHIEVED / MISSED / CANCELLED
  createdById   String?
  createdByName String?
  achievedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([studentId, status])
}

// Academic Coach monthly review (one per student per period).
model MonthlyReview {
  id             String   @id @default(uuid())
  studentId      String
  coachId        String?
  periodStart    DateTime
  periodEnd      DateTime
  monthLabel     String // "March 2026"
  academic       Int? // 1..5
  attendance     Int?
  behavior       Int?
  participation  Int?
  learningSpeed  Int?
  homework       Int?
  communication  Int?
  recommendation String? // CONTINUE_BATCH / MOVE_ADVANCED / EXTRA_PRACTICE / PARENT_MEETING
  remarks        String?
  actorId        String?
  actorName      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([studentId, periodStart])
  @@index([studentId])
}

// Badge catalogue. Auto-award rules live in the engine; criteria here is display.
model Badge {
  id          String   @id @default(uuid())
  code        String   @unique // PERFECT_ATTENDANCE / ASSIGNMENT_CHAMPION / ...
  name        String
  description String?
  icon        String?
  tone        String? // good / accent / warning
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  awards StudentBadge[]
}

model StudentBadge {
  id        String   @id @default(uuid())
  studentId String
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  awardedAt DateTime @default(now())
  meta      Json?

  @@unique([studentId, badgeId])
  @@index([studentId])
}

// Risk flag raised by the engine when thresholds trip; coach is notified.
model ProgressRiskFlag {
  id            String    @id @default(uuid())
  studentId     String
  level         String    @default("AT_RISK") // AT_RISK / CRITICAL
  reasons       String[]  @default([])
  attendancePct Float?
  assignmentPct Float?
  assessmentPct Float?
  status        String    @default("OPEN") // OPEN / ACKNOWLEDGED / RESOLVED
  note          String?
  resolvedById  String?
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([studentId, status])
  @@index([status])
}

// Parent meeting scheduled/tracked by the Academic Coach.
model ParentMeeting {
  id           String    @id @default(uuid())
  studentId    String
  coachId      String?
  scheduledAt  DateTime
  status       String    @default("SCHEDULED") // SCHEDULED / COMPLETED / CANCELLED
  agenda       String?
  notes        String?
  actionItems  Json? // [{ text, done }]
  nextReviewAt DateTime?
  actorId      String?
  actorName    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([studentId, status])
}

// Monthly snapshot of computed progress — powers trend + timeline charts.
model ProgressSnapshot {
  id            String   @id @default(uuid())
  studentId     String
  periodStart   DateTime
  periodEnd     DateTime
  monthLabel    String
  attendancePct Float    @default(0)
  assignmentPct Float    @default(0)
  assessmentPct Float    @default(0)
  feedbackScore Float    @default(0)
  coachScore    Float    @default(0)
  overallScore  Float    @default(0)
  statusLabel   String   @default("AVERAGE") // EXCELLENT / GOOD / AVERAGE / NEEDS_ATTENTION / CRITICAL
  rank          Int?
  createdAt     DateTime @default(now())

  @@unique([studentId, periodStart])
  @@index([studentId])
}

// ─── Finance & Reporting ──────────────────────────────────────────────────────
// Extends the existing Invoice / Payment / Payout / Expense building blocks with
// fee plans, discounts, scholarships, refunds, receipts and payroll config.
// Foreign keys that would over-couple the academic models stay plain-id (resolved
// in the service, like StudentProfile.coachId); the raw-SQL migration adds
// DB-level FKs for cascade integrity where a relation is declared above.

enum FeePlanCycle {
  ONE_TIME
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
  CUSTOM
}

enum FeeComponentType {
  ADMISSION
  COURSE
  REGISTRATION
  MATERIAL
  EXAMINATION
  CERTIFICATE
  OTHER
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum DiscountReason {
  SCHOLARSHIP
  SIBLING
  PROMOTIONAL
  STAFF
  MANUAL
}

enum ScholarshipStatus {
  REQUESTED
  APPROVED
  REJECTED
  APPLIED
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED
  PROCESSED
}

enum PayrollModel {
  FIXED
  PER_CLASS
  PER_HOUR
  PER_STUDENT
  HYBRID
}

// A reusable fee plan (Monthly / Quarterly / Yearly / Custom) with N components.
model FeePlan {
  id          String       @id @default(uuid())
  name        String
  cycle       FeePlanCycle @default(MONTHLY)
  courseId    String?      // optional link to a course (plain id, resolved in service)
  currency    String       @default("USD")
  description String?
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  components  FeePlanComponent[]
  assignments StudentFeeAssignment[]
  packages    Package[]

  @@index([active])
}

model FeePlanComponent {
  id     String           @id @default(uuid())
  planId String
  plan   FeePlan          @relation(fields: [planId], references: [id], onDelete: Cascade)
  type   FeeComponentType @default(COURSE)
  label  String
  amount Decimal          @db.Decimal(10, 2)

  @@index([planId])
}

// Links a student to a recurring fee plan. The auto-generator reads active rows
// whose nextRunAt is due and mints an invoice for the period.
model StudentFeeAssignment {
  id           String         @id @default(uuid())
  studentId    String
  student      StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  planId       String
  plan         FeePlan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  startDate    DateTime       @default(now())
  nextRunAt    DateTime?      // when the next recurring invoice is due (null = one-time/done)
  active       Boolean        @default(true)
  autoGenerate Boolean        @default(true)
  discountId   String?        // default discount applied to generated invoices
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([studentId])
  @@index([planId])
  @@index([active])
}

// A reusable discount definition (percentage or fixed) applied to invoices.
model Discount {
  id          String         @id @default(uuid())
  code        String?        @unique
  name        String
  type        DiscountType   @default(PERCENTAGE)
  value       Decimal        @db.Decimal(10, 2)
  reason      DiscountReason @default(PROMOTIONAL)
  description String?
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([active])
}

// A scholarship request → review → approve → applied (becomes an invoice discount).
model Scholarship {
  id              String            @id @default(uuid())
  studentId       String
  student         StudentProfile    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  name            String
  type            DiscountType      @default(PERCENTAGE)
  value           Decimal           @db.Decimal(10, 2)
  reason          String?
  status          ScholarshipStatus @default(REQUESTED)
  requestedById   String?
  requestedByName String?
  reviewedById    String?
  reviewedByName  String?
  reviewNotes     String?
  appliedAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([studentId])
  @@index([status])
}

// A refund request → approve → processed, with immutable history.
model Refund {
  id              String       @id @default(uuid())
  invoiceId       String?
  invoice         Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  paymentId       String?
  studentId       String?
  amount          Decimal      @db.Decimal(10, 2)
  currency        String       @default("USD")
  reason          String
  method          String?      // BANK_TRANSFER / UPI / CARD / CASH / ...
  status          RefundStatus @default(REQUESTED)
  requestedById   String?
  requestedByName String?
  approvedById    String?
  approvedByName  String?
  reviewNotes     String?
  processedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([status])
  @@index([studentId])
}

// How a teacher / staff member is paid. Drives payout bulk-generation.
model PayrollConfig {
  id             String       @id @default(uuid())
  userId         String       @unique
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  model          PayrollModel @default(FIXED)
  baseSalary     Decimal?     @db.Decimal(10, 2)
  perClassRate   Decimal?     @db.Decimal(10, 2)
  perHourRate    Decimal?     @db.Decimal(10, 2)
  perStudentRate Decimal?     @db.Decimal(10, 2)
  standardBonus  Decimal      @default(0) @db.Decimal(10, 2)
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}



// ---------------------------------------------------------------------------
// Dashboard Management
// ---------------------------------------------------------------------------

// A parent login linked to one or more children. A parent may have several
// children, and a student may have two guardians with separate logins.
model ParentLink {
  id           String         @id @default(uuid())
  parentUserId String
  parentUser   User           @relation(fields: [parentUserId], references: [id], onDelete: Cascade)
  studentId    String
  student      StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  relationship String?
  isPrimary    Boolean        @default(false)
  createdAt    DateTime       @default(now())

  @@unique([parentUserId, studentId])
  @@index([parentUserId])
  @@index([studentId])
}

// Registry of every dashboard widget. Seeded by scripts/migrate-dashboard.cjs;
// `roles` is the set of role dashboards a widget is even eligible for.
model DashboardWidget {
  key         String   @id
  title       String
  description String?
  category    String   @default("KPI") // KPI | CHART | TABLE | LIST | ACTION
  defaultSize String   @default("MD")  // SM | MD | LG | FULL
  roles       String[] @default([])
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  roleSettings RoleWidgetSetting[]
  userLayouts  UserWidgetLayout[]
}

// Admin-controlled enable/disable of a widget for a whole role.
model RoleWidgetSetting {
  id        String          @id @default(uuid())
  role      Role
  widgetKey String
  widget    DashboardWidget @relation(fields: [widgetKey], references: [key], onDelete: Cascade)
  enabled   Boolean         @default(true)
  order     Int             @default(0)
  updatedAt DateTime        @updatedAt

  @@unique([role, widgetKey])
  @@index([role])
}

// Per-user personalisation on top of the role settings.
model UserWidgetLayout {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgetKey String
  widget    DashboardWidget @relation(fields: [widgetKey], references: [key], onDelete: Cascade)
  order     Int             @default(0)
  size      String?
  hidden    Boolean         @default(false)
  updatedAt DateTime        @updatedAt

  @@unique([userId, widgetKey])
  @@index([userId])
}

model Announcement {
  id            String    @id @default(uuid())
  title         String
  body          String
  type          String    @default("GENERAL") // HOLIDAY | MAINTENANCE | EXAM | COURSE | GENERAL
  audience      String[]  @default([])        // Role names; empty = everyone
  pinned        Boolean   @default(false)
  active        Boolean   @default(true)
  link          String?
  publishedAt   DateTime?
  expiresAt     DateTime?
  createdById   String?
  createdByName String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  reads AnnouncementRead[]

  @@index([active, publishedAt])
}

model AnnouncementRead {
  id             String       @id @default(uuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt         DateTime     @default(now())

  @@unique([announcementId, userId])
  @@index([userId])
}
