// LMS data model.
// DATABASE_URL points at local Docker Postgres today and at Supabase later;
// DIRECT_URL exists because Prisma migrations cannot run through a pooler.

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  // NestJS compiles to CommonJS; without this the generated client emits ESM
  // and ts-node/Node disagree about how to load it.
  moduleFormat = "cjs"
  runtime      = "nodejs"
}

// Prisma 7 keeps connection URLs out of the schema — see prisma.config.ts.
datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SUPERVISOR
  ACADEMIC_COACH
  TEACHER
  STUDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
  TRIAL
  PAUSED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EnrollmentStatus {
  TRIAL
  PENDING
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum ClassStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

enum SubmissionStatus {
  ASSIGNED
  SUBMITTED
  EVALUATED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

// ─── Identity ─────────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  firstName    String
  lastName     String
  role         Role
  status       UserStatus @default(ACTIVE)
  country      String?
  timezone     String?
  avatarUrl    String?
  lastLoginAt  DateTime?
  phone        String?
  gender       String?
  joiningDate  DateTime?
  salary       Decimal?   @db.Decimal(10, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  studentProfile StudentProfile?
  teacherProfile TeacherProfile?
  refreshTokens  RefreshToken[]
  leaveRequests  LeaveRequest[]

  @@index([role, status])
}

// Only the hash is stored, so a database leak cannot replay a session.
model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model StudentProfile {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentCode     String    @unique
  phone           String?
  gender          String?
  dateOfBirth     DateTime?
  guardianName    String?
  profession      String?
  fees            Decimal?  @db.Decimal(10, 2)
  joiningDate     DateTime?
  lastPaymentDate DateTime?
  nextPaymentDate DateTime?

  enrollments Enrollment[]
  submissions Submission[]
  invoices    Invoice[]
  attendance  ClassAttendee[]
}

model TeacherProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teacherCode    String   @unique
  bio            String?
  specialisation String?
  hourlyRate     Decimal? @db.Decimal(10, 2)

  enrollments Enrollment[]
  classes     ClassSession[]
}

// ─── Catalogue ────────────────────────────────────────────────────────────────

model Level {
  id      String   @id @default(uuid())
  name    String   @unique
  order   Int
  courses Course[]
}

model Course {
  id            String       @id @default(uuid())
  title         String
  slug          String       @unique
  description   String?
  levelId       String?
  level         Level?       @relation(fields: [levelId], references: [id], onDelete: SetNull)
  price         Decimal      @db.Decimal(10, 2)
  durationWeeks Int          @default(12)
  status        CourseStatus @default(DRAFT)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  enrollments Enrollment[]
  classes     ClassSession[]
  assignments Assignment[]

  @@index([status])
}

model Package {
  id              String   @id @default(uuid())
  name            String   @unique
  description     String?
  price           Decimal  @db.Decimal(10, 2)
  classesPerMonth Int
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  enrollments Enrollment[]
}

// ─── Learning ─────────────────────────────────────────────────────────────────

model Enrollment {
  id          String           @id @default(uuid())
  studentId   String
  student     StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacherId   String?
  teacher     TeacherProfile?  @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  packageId   String?
  package     Package?         @relation(fields: [packageId], references: [id], onDelete: SetNull)
  status      EnrollmentStatus @default(PENDING)
  progress    Int              @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // A student sits in a given course once.
  @@unique([studentId, courseId])
  @@index([status])
}

model ClassSession {
  id         String         @id @default(uuid())
  courseId   String
  course     Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacherId  String
  teacher    TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  title      String
  startsAt   DateTime
  endsAt     DateTime
  status     ClassStatus    @default(SCHEDULED)
  meetingUrl String?
  createdAt  DateTime       @default(now())

  attendees ClassAttendee[]

  @@index([startsAt])
  @@index([teacherId, startsAt])
}

model ClassAttendee {
  id        String         @id @default(uuid())
  classId   String
  class     ClassSession   @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  attended  Boolean        @default(false)
  joinedAt  DateTime?

  @@unique([classId, studentId])
}

model Assignment {
  id          String   @id @default(uuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueAt       DateTime?
  createdAt   DateTime @default(now())

  submissions Submission[]
}

model Submission {
  id           String           @id @default(uuid())
  assignmentId String
  assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      StudentProfile   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status       SubmissionStatus @default(ASSIGNED)
  content      String?
  fileUrl      String?
  grade        Int?
  feedback     String?
  submittedAt  DateTime?
  evaluatedAt  DateTime?

  @@unique([assignmentId, studentId])
}

// ─── Billing ──────────────────────────────────────────────────────────────────

model Invoice {
  id        String         @id @default(uuid())
  number    String         @unique
  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount    Decimal        @db.Decimal(10, 2)
  currency  String         @default("USD")
  status    InvoiceStatus  @default(DRAFT)
  issuedAt  DateTime       @default(now())
  dueAt     DateTime?
  paidAt    DateTime?
  notes     String?

  payments Payment[]

  @@index([status])
}

model Payment {
  id          String        @id @default(uuid())
  invoiceId   String
  invoice     Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount      Decimal       @db.Decimal(10, 2)
  provider    String        @default("stripe")
  providerRef String?
  status      PaymentStatus @default(PENDING)
  paidAt      DateTime?
  createdAt   DateTime      @default(now())

  @@index([invoiceId])
}

model SystemSetting {
  key   String @id
  value String
}

enum CandidateStatus {
  NEW
  SHORTLISTED
  REJECTED
  WAITING
  APPROVED
}

model Candidate {
  id             String          @id @default(uuid())
  firstName      String
  lastName       String
  email          String          @unique
  phone          String?
  position       String          // e.g. "Quran Teacher", "Arabic Teacher"
  resumeUrl      String?
  status         CandidateStatus @default(NEW)
  notes          String?
  appliedAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([status])
}

enum LeaveType {
  SICK
  CASUAL
  ANNUAL
  UNPAID
  OTHER
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  DECLINED
}

model LeaveRequest {
  id           String             @id @default(uuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType    LeaveType          @default(CASUAL)
  startDate    DateTime
  endDate      DateTime
  reason       String
  status       LeaveRequestStatus @default(PENDING)
  adminNotes   String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([userId])
  @@index([status])
}

// ─── Trial Classes ────────────────────────────────────────────────────────────

enum TrialStatus {
  PENDING
  SCHEDULED
  COMPLETED
}

model TrialClass {
  id                 String      @id @default(uuid())
  name               String
  email              String
  mobile             String
  country            String
  course             String
  prefTeacherGender  String      // "Male", "Female", "Any"
  status             TrialStatus @default(PENDING)
  age                Int
  goals              String?
  scheduledTime      String?     // Date or text string
  assignedTeacher    String?
  meetLink           String?
  pronunciationGrade String?
  fluencyGrade       String?
  focusGrade         String?
  recommendedLevel   String?
  evaluationNotes    String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

model Category {
  id        String   @id @default(uuid())
  name      String
  type      String   // "COURSE", "ASSIGNMENT", "ASSESSMENT", "KNOWLEDGEBASE"
  createdAt DateTime @default(now())

  @@unique([name, type])
}

model LmsCourse {
  id            String   @id @default(uuid())
  code          String   @unique
  title         String
  category      String
  level         String
  studentsCount Int      @default(0)
  teachersCount Int      @default(0)
  status        String   @default("Active")
  createdAt     String
  description   String
}

model LmsAssignment {
  id               String   @id @default(uuid())
  title            String
  courseCode       String
  courseTitle      String
  category         String
  studentsCount    Int      @default(0)
  submissionsCount Int      @default(0)
  evaluatedCount   Int      @default(0)
  dueDate          String
  status           String   @default("Active")
  description      String
}

model LmsAssessment {
  id             String   @id @default(uuid())
  title          String
  courseCode     String
  courseTitle    String
  questionsCount Int
  duration       Int
  category       String
  avgScore       Float    @default(0)
  status         String   @default("Active")
  description    String
}

model LmsKnowledgebase {
  id          String   @id @default(uuid())
  title       String
  courseCode  String
  courseTitle String
  format      String
  sizeMB      Float
  category    String
  downloads   Int      @default(0)
  status      String   @default("Active")
  description String
  // Points at the stored file (relative path under /uploads) for uploaded
  // resources, or an external URL for "Link" resources. Null until a file is
  // attached. fileName keeps the original name for the download prompt.
  fileUrl     String?
  fileName    String?
}

model LmsPackage {
  id          String   @id @default(uuid())
  title       String
  price       Float
  billing     String
  level       String
  courses     String[]
  features    String[]
  status      String   @default("Active")
  description String
}


