// A single fee line on an invoice (Course Fee, Admission Fee, ...).
model InvoiceItem {
  id        String           @id @default(uuid())
  invoiceId String
  invoice   Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
