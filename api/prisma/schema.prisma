// A payment receipt (first-class, numbered, e-mailable/downloadable).
model Receipt {
  id        String   @id @default(uuid())
  number    String   @unique // RCPT-2026-000001
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
