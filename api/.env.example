# Supabase Postgres. Use the POOLER host for both — the db.<ref>.supabase.co
# direct host is IPv6-only and unreachable from most networks.
#   DATABASE_URL -> port 6543 (transaction mode) — used by the running app
#   DIRECT_URL   -> port 5432 (session mode)     — used by migrations (DDL)
# URL-encode special characters in the password (@ -> %40, # -> %23).
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

PORT=5000

# Comma-separated list of allowed browser origins (the deployed web app).
CORS_ORIGIN="https://your-app.vercel.app"

# Generate fresh, random values per environment:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=""
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET=""
JWT_REFRESH_TTL="7d"

# --- Email (OTP delivery) ---
# Local dev can use Gmail directly (just set SMTP_USER + SMTP_PASS below).
# Render/production blocks the standard SMTP ports (25/465/587), so use a
# transactional provider (e.g. Brevo) over port 2525 by setting SMTP_HOST.
#   Brevo: SMTP_HOST=smtp-relay.brevo.com  SMTP_PORT=2525
#          SMTP_USER=<brevo-login>  SMTP_PASS=<brevo-smtp-key>
#          SMTP_FROM=<your-verified-sender-email>
SMTP_USER=""
SMTP_PASS=""
# Leave SMTP_HOST empty to use Gmail. Set it to switch to a relay provider.
SMTP_HOST=""
SMTP_PORT="2525"
SMTP_SECURE="false"
SMTP_FROM=""

# ── Stripe ────────────────────────────────────────────────────────────────────
# Absent keys disable online payments loudly: the API refuses with 503 and logs
# a warning at boot, rather than silently accepting a payment that never happens.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# From Developers -> Webhooks after adding the endpoint
#   POST {API_URL}/api/payments/webhook   (payment_intent.succeeded, payment_intent.payment_failed)
# The signature is checked against the raw request body; without this secret no
# event is trusted.
STRIPE_WEBHOOK_SECRET=whsec_...
